# =============================================================================
# Peer Review System - Environment Configuration
# Owner: Yanxiao Zheng (Database & Security, AI Integration)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/peerreview

# Application Port
PORT=8080

# -----------------------------------------------------------------------------
# Authentication & Authorization
# -----------------------------------------------------------------------------
# Authentication mode: 'dev' (header-based) | 'sso' (CAS/SAML) | 'cas'
# WARNING: Never use 'dev' in production!
AUTH_MODE=dev

# CAS/SSO Configuration (required when AUTH_MODE=sso or AUTH_MODE=cas)
# CAS_URL=https://cas.university.edu/cas
# CAS_VERSION=3.0
# SERVICE_URL=https://peerreview.university.edu/auth/callback
# SSO_ROLE_ATTRIBUTE=eduPersonAffiliation
# SSO_COURSE_ATTRIBUTE=courseMembership

# Development-only authentication headers (when AUTH_MODE=dev):
# x-user-id: UUID of user
# x-user-role: student|instructor|admin
# x-user-course: Course identifier
# x-user-group: Group identifier (optional)

# -----------------------------------------------------------------------------
# Security & Privacy (Yanxiao v2)
# -----------------------------------------------------------------------------
# Salt for audit log tamper detection (min 32 chars, use strong random value)
AUDIT_SALT=change-this-to-random-string-in-production-min-32-chars

# Salt for privacy-preserving hashing of IP/UA (min 32 chars, different from AUDIT_SALT)
PRIVACY_SALT=change-this-to-different-random-string-min-32-chars

# Session secret for SSO (required when AUTH_MODE=sso)
# SESSION_SECRET=strong-random-secret-min-64-chars

# -----------------------------------------------------------------------------
# AI Integration (Bias Detection & NLP)
# -----------------------------------------------------------------------------
# AI service provider: 'openai' | 'anthropic' | 'azure' | 'perspective' | 'mock'
AI_PROVIDER=mock

# OpenAI Configuration (if AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4
# OPENAI_ORG_ID=org-...

# Anthropic Configuration (if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Azure OpenAI Configuration (if AI_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# Google Perspective API (for toxicity detection)
# PERSPECTIVE_API_KEY=...

# AI Analysis Configuration
# Enable bias detection on review submission
AI_BIAS_DETECTION_ENABLED=true

# Toxicity threshold (0.0-1.0) to flag as risky
AI_TOXICITY_THRESHOLD=0.7

# Politeness threshold (0.0-1.0) below which to flag as impolite
AI_POLITENESS_THRESHOLD=0.3

# Enable AI-generated rewrite suggestions
AI_REWRITE_SUGGESTIONS_ENABLED=true

# Model version identifier for tracking
AI_MODEL_VERSION=v1.0-mock

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Storage encryption (optional but recommended)
# S3_ENCRYPTION_KEY=your-s3-sse-kms-key-id
# STORAGE_ENCRYPTION=true

# File upload limits
# MAX_FILE_SIZE=10485760
# ALLOWED_FILE_TYPES=pdf,docx,txt

# -----------------------------------------------------------------------------
# Rate Limiting (optional)
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Enable audit log integrity verification on read
AUDIT_VERIFY_INTEGRITY=false

# Grafana/Prometheus metrics endpoint (optional)
# METRICS_ENABLED=false
# METRICS_PORT=9090

