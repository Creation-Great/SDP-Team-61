DATABASE_URL=postgres://postgres:postgres@localhost:5432/peerreview
PORT=8080

# Dev-only headers: x-user-id, x-user-role (student|instructor|admin), x-user-course, x-user-group

# Security & Privacy (Yanxiao v2)
AUDIT_SALT=change-this-to-random-string-in-production-min-32-chars
PRIVACY_SALT=change-this-to-different-random-string-min-32-chars

# Storage encryption (optional but recommended)
# S3_ENCRYPTION_KEY=your-s3-sse-kms-key-id
# STORAGE_ENCRYPTION=true

# Rate limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
